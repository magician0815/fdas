# FDAS多容器部署方案 - 环境变量配置模板
# 复制为 .env 使用
# ⚠️ 安全警告: 生产环境必须修改所有默认值！

# ==================== 依赖说明 ====================
# 关键Python依赖及其用途:
# - bcrypt>=4.0.0    : 密码哈希算法（init-db.sql中admin密码必需）
#                       缺失会导致登录时 ModuleNotFoundError
# - psycopg2-binary  : APScheduler PostgreSQL同步驱动
#                       APScheduler的SQLAlchemyJobStore需要同步驱动
#                       asyncpg为异步驱动，无法满足APScheduler需求
#                       缺失会导致调度器启动失败
# - slowapi>=0.1.9   : API速率限制（login接口必需）
#                       使用时参数命名必须为 request（非http_request）
#                       否则会导致 INTERNAL_ERROR
#
# 数据库Schema注意事项:
# - apscheduler_jobs.next_run_time 使用 NUMERIC(24,6) 类型存储Unix timestamp
# - 使用 TIMESTAMP 类型会导致 "operator does not exist: timestamp <= numeric" 错误
# - 迁移数据时需检查目标schema兼容性

# ==================== 数据库配置 ====================
# PostgreSQL密码（生产环境必须修改）
# ⚠️ 使用强密码（至少16字符，包含大小写字母、数字、特殊字符）
DB_PASSWORD=your-secure-db-password-here

# 数据库端口（可选修改）
DB_PORT=5432

# ==================== 后端安全配置 ====================
# Session密钥（必须至少32字符）
# 可使用以下命令生成:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ 生产环境必须配置，不可使用默认值
SESSION_SECRET=change-this-in-production-min-32-characters

# ==================== 应用配置 ====================
# 调试模式（生产环境必须false）
DEBUG=false

# 应用HTTP端口
APP_PORT=8000

# ==================== CORS配置 ====================
# 允许的前端域名（JSON数组格式）
# 生产环境必须配置为实际域名，不可使用localhost
ALLOWED_ORIGINS=["https://your-domain.com"]

# ==================== IP验证（可选） ====================
# 是否启用Session IP验证
# 生产环境建议true，可防止Session被盗用
ENABLE_IP_VALIDATION=false

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 备份配置 ====================
BACKUP_DIR=/var/backups/fdas

# ==================== 安全警告 ====================
# ⚠️ SESSION_SECRET 必须至少32字符
# ⚠️ DB_PASSWORD 必须使用强密码
# ⚠️ ALLOWED_ORIGINS 生产环境不可使用localhost
# ⚠️ 首次登录后立即修改admin密码（默认admin123）
# ⚠️ 建议启用ENABLE_IP_VALIDATION